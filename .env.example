# API
ENERGON_BIND_ADDR=127.0.0.1:3001
DATABASE_URL=postgres://energon:energon@localhost:5432/energon
ENERGON_API_KEY_PEPPER=
ENERGON_ADMIN_TOKEN=
ENERGON_DEV_AUTH=false
ENERGON_RETRIEVAL_CANDIDATE_LIMIT=500

# Worker / embeddings
ENERGON_EMBEDDING_MODEL=text-embedding-3-small
ENERGON_EMBEDDING_BATCH_SIZE=16
ENERGON_WORKER_ONCE=false
OPENAI_API_KEY=

# Web
NEXT_PUBLIC_SITE_URL=https://energon.os
NEXT_PUBLIC_ENERGON_API_BASE_URL=http://127.0.0.1:3001

# Storage roadmap / large documents
R2_BUCKET=energon-docs

# x402 paid API gates
ENERGON_X402_ENABLED=false
ENERGON_X402_PAY_TO=
ENERGON_X402_NETWORK=eip155:84532
ENERGON_X402_ASSET=0x036CbD53842c5426634e7929541eC2318f3dCF7e
ENERGON_X402_FACILITATOR_URL=https://x402.org/facilitator
ENERGON_X402_FACILITATOR_BEARER=
ENERGON_X402_MAX_TIMEOUT_SECONDS=60
ENERGON_X402_ACCEPT_UNVERIFIED=false
