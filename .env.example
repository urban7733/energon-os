# ─── Rust API (energon-api) ─────────────────────────────────────────────────
ENERGON_BIND_ADDR=127.0.0.1:3001
# Shared by the API, worker, and the Next.js Better Auth adapter.
DATABASE_URL=postgres://energon:energon@localhost:5432/energon
# Required when DATABASE_URL is set. Peppers SHA-256 agent API key hashes.
ENERGON_API_KEY_PEPPER=
# BOOTSTRAP ONLY: static token for POST /v1/admin/agents. Use the
# JWT-authenticated /v1/orgs/{org_id}/... routes for day-to-day management.
ENERGON_ADMIN_TOKEN=
# Accept x-energon-* identity headers without a bearer key (local dev only).
ENERGON_DEV_AUTH=false
ENERGON_RETRIEVAL_CANDIDATE_LIMIT=500

# ─── Operator JWT verification (Better Auth JWKS) ───────────────────────────
# Where the Rust API fetches Ed25519 public keys to verify operator JWTs.
ENERGON_JWKS_URL=http://localhost:3000/api/auth/jwks
# Optional issuer/audience validation; must match apps/web auth config.
ENERGON_JWT_ISSUER=http://localhost:3000
ENERGON_JWT_AUDIENCE=energon-api
# JWKS cache refresh interval in seconds (also refetches on unknown kid).
ENERGON_JWKS_REFRESH_SECONDS=300

# ─── Rate limiting / request limits ──────────────────────────────────────────
# Token bucket per API key (hashed) or client IP. 429 when exhausted.
ENERGON_RATE_LIMIT_RPS=20
ENERGON_RATE_LIMIT_BURST=40
# Maximum request body size in bytes (default 1 MiB).
ENERGON_MAX_BODY_BYTES=1048576
# Comma-separated browser origins allowed on management routes.
ENERGON_WEB_ORIGIN=http://localhost:3000

# ─── Worker / embeddings ─────────────────────────────────────────────────────
ENERGON_EMBEDDING_MODEL=text-embedding-3-small
ENERGON_EMBEDDING_BATCH_SIZE=16
ENERGON_WORKER_ONCE=false
# Also enables query-time semantic retrieval in the API when set.
OPENAI_API_KEY=

# ─── Web (apps/web) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://energon.os
NEXT_PUBLIC_ENERGON_API_BASE_URL=http://127.0.0.1:3001
# Better Auth: long random secret (e.g. `openssl rand -base64 32`).
BETTER_AUTH_SECRET=
# Public base URL of the Next.js app (issuer for operator JWTs).
BETTER_AUTH_URL=http://localhost:3000

# ─── GitHub login (optional; enabled when both vars are set) ──────────────────
# GitHub OAuth app: callback URL ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Storage roadmap / large documents ───────────────────────────────────────
R2_BUCKET=energon-docs

# ─── x402 paid API gates ─────────────────────────────────────────────────────
ENERGON_X402_ENABLED=false
# Your receiving wallet address. Required when x402 is enabled.
ENERGON_X402_PAY_TO=
# Defaults: Base Sepolia testnet USDC. For Base mainnet set
# ENERGON_X402_NETWORK=eip155:8453 and
# ENERGON_X402_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# (see docs/crypto-payments.md).
ENERGON_X402_NETWORK=eip155:84532
ENERGON_X402_ASSET=0x036CbD53842c5426634e7929541eC2318f3dCF7e
ENERGON_X402_FACILITATOR_URL=https://x402.org/facilitator
ENERGON_X402_FACILITATOR_BEARER=
ENERGON_X402_MAX_TIMEOUT_SECONDS=60
ENERGON_X402_ACCEPT_UNVERIFIED=false

# ─── Human Base-USDC plan checkout ──────────────────────────────────────────
# The public receiving wallet is shared with x402. Set an RPC URL from your
# production RPC provider; Base's public RPC endpoints are test/demo only.
ENERGON_BASE_RPC_URL=
# Optional overrides; default to the x402 network/asset above.
ENERGON_BILLING_NETWORK=eip155:84532
ENERGON_BILLING_ASSET=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ─── Per-route pricing (USDC micro units; 1000 = $0.001) ─────────────────────
ENERGON_PRICE_MEMORY_WRITE_MICRO=1000
ENERGON_PRICE_MEMORY_PROMOTE_MICRO=1000
ENERGON_PRICE_CONTEXT_BUILD_MICRO=3000
ENERGON_PRICE_AUDIT_READ_MICRO=500
ENERGON_PRICE_VAULT_EXPORT_MICRO=5000
